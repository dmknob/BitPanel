{
  "name": "bitpanel",
  "version": "3.0.0",
  "description": "Um painel de indicadores sobre Bitcoin com backend em Node.js (TypeScript) e banco de dados SQLite.",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node server.ts",
    "build": "tsc",
    "start:prod": "node dist/server.js",
    "dev": "ts-node server.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "generate-vapid": "node scripts/generate-vapid.js"
  },
  "keywords": [
    "bitcoin",
    "dashboard",
    "nodejs",
    "typescript",
    "sqlite",
    "DCA"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "node-cron": "^4.2.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server.ts",
      "!**/node_modules/**"
    ]
  }
}
