# Porta do servidor (padrão: 3000)
PORT=3000

# Nome do arquivo do banco de dados SQLite
DB_NAME=bitpanel.sqlite

# Intervalo de atualização em segundos (padrão: 600 = 10 minutos)
UPDATE_INTERVAL_SECONDS=600

# Chave de API do CoinGecko (obrigatória)
# Obtenha em: https://www.coingecko.com/api
COINGECKO_API_KEY=SUA_API_KEY_AQUI

# Origem permitida para CORS (deixe em branco para desabilitar CORS, use '*' apenas em dev)
# Exemplo: https://meubitpanel.com.br
ALLOWED_ORIGIN=

# DSN do Sentry para monitoramento de erros (opcional)
# Deixe em branco para desabilitar
SENTRY_DSN=

# VAPID Keys para Push Notifications de alertas de preço (opcional)
# Gere com: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@bitpanel.local
